# Environment Identifier (development / production)
ENV=development
DEBUG=true
PORT=8000

# Security Credentials
# GEMINI_API_KEY: Required for Gemini AI API calls. Set your API Key from Google AI Studio.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# JWT Token configuration
JWT_SECRET="YOUR_SUPER_SECRET_KEY_FOR_LOCAL_DEVELOPMENT_COMPLIANCE_2026"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database & Caching
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379/0"

# Enterprise CORS & Domain Permissions
FRONTEND_URL="http://localhost:3000"
CORS_WHITELIST="http://localhost:3000,http://localhost:5173"

# Vector Store / RAG Setup
EMBEDDING_MODEL="text-embedding-004"
DEFAULT_CHAT_MODEL="gemini-2.5-flash"
VECTOR_SEARCH_TOP_K=5
CONTEXT_COMPRESSION_ENABLED=true
