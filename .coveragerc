[run]
branch = True
source = app
omit =
    app/build_json.py
    tests/*

[report]
show_missing = True
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    pass
    class .*\(Protocol\):

[html]
directory = htmlcov
